# ─────────────────────────────────────────────
# CrashGuard AI — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Slack Alerts (optional) ──
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ── Gmail SMTP Email Alerts (optional) ──
# To get Gmail App Password:
# Google Account → Security → 2-Step Verification → App Passwords → Mail
SMTP_USER=           # Gmail address (e.g., your.email@gmail.com)
SMTP_PASS=           # Gmail App Password (16 chars, NOT your Google password)
ALERT_EMAIL=         # Where to receive alerts (e.g., oncall@yourteam.com)
SMTP_SERVER=smtp.gmail.com  # default
SMTP_PORT=587               # default

# ── Demo Mode ──
# Set to 1 for stable demo behavior (seed=42)
DEMO_MODE=1
